<UserControl
    x:Class="PicLens.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PicLens.Converters"
    xmlns:vm="using:PicLens.ViewModels"
    x:DataType="vm:MainPageViewModel"
    x:Name="Root"
    Focusable="True">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F8F9FA" />
        <SolidColorBrush x:Key="CommandBarBrush" Color="#F1F3F5" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#FBFCFD" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TileFrameBrush" Color="#EEF0F2" />
        <SolidColorBrush x:Key="LineBrush" Color="#E2E5E9" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1F2328" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5F6368" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#7A8088" />
        <SolidColorBrush x:Key="HoverBrush" Color="#E8EBEF" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#DFECFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4" />
        <SolidColorBrush x:Key="ViewerCanvasBrush" Color="#F7F7F7" />
        <converters:ImagePathConverter x:Key="ImagePathConverter" />
        <StreamGeometry x:Key="IconBack">M12.7347,4.20949 C13.0332,3.92233 13.508,3.93153 13.7952,4.23005 C14.0823,4.52857 14.0731,5.00335 13.7746,5.29051 L5.50039,13.25 L24.2532,13.25 C24.6674,13.25 25.0032,13.5858 25.0032,13.9999982 C25.0032,14.4142 24.6674,14.75 24.2532,14.75 L5.50137,14.75 L13.7746,22.7085 C14.0731,22.9957 14.0823,23.4705 13.7952,23.769 C13.508,24.0675 13.0332,24.0767 12.7347,23.7896 L3.30673,14.7202 C2.89776,14.3268 2.89776,13.6723 3.30673,13.2788 L12.7347,4.20949 Z</StreamGeometry>
