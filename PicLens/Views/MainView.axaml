<UserControl
    x:Class="PicLens.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PicLens.Converters"
    xmlns:vm="using:PicLens.ViewModels"
    x:DataType="vm:MainPageViewModel"
    x:Name="Root"
    Focusable="True">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F8F9FA" />
        <SolidColorBrush x:Key="CommandBarBrush" Color="#F1F3F5" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#FBFCFD" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TileFrameBrush" Color="#EEF0F2" />
        <SolidColorBrush x:Key="LineBrush" Color="#E2E5E9" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1F2328" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5F6368" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#7A8088" />
        <SolidColorBrush x:Key="HoverBrush" Color="#E8EBEF" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#DFECFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4" />
        <SolidColorBrush x:Key="ViewerCanvasBrush" Color="#F7F7F7" />
        <converters:ImagePathConverter x:Key="ImagePathConverter" />
        <StreamGeometry x:Key="IconBack">M20,11L7.83,11L13.42,5.41L12,4L4,12L12,20L13.42,18.59L7.83,13L20,13Z</StreamGeometry>
        <StreamGeometry x:Key="IconForward">M4,11L16.17,11L10.58,5.41L12,4L20,12L12,20L10.58,18.59L16.17,13L4,13Z</StreamGeometry>
        <StreamGeometry x:Key="IconRefresh">M17.65,6.35C16.2,4.9 14.21,4 12,4C7.58,4 4.01,7.58 4.01,12C4.01,16.42 7.58,20 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18C8.69,18 6,15.31 6,12C6,8.69 8.69,6 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4Z</StreamGeometry>
        <StreamGeometry x:Key="IconFolder">M10,4L12,6H20C21.1,6 22,6.9 22,8V18C22,19.1 21.1,20 20,20H4C2.9,20 2,19.1 2,18V6C2,4.9 2.9,4 4,4Z</StreamGeometry>
        <StreamGeometry x:Key="IconMore">M12,8C13.1,8 14,7.1 14,6C14,4.9 13.1,4 12,4C10.9,4 10,4.9 10,6C10,7.1 10.9,8 12,8M12,10C10.9,10 10,10.9 10,12C10,13.1 10.9,14 12,14C13.1,14 14,13.1 14,12C14,10.9 13.1,10 12,10M12,16C10.9,16 10,16.9 10,18C10,19.1 10.9,20 12,20C13.1,20 14,19.1 14,18C14,16.9 13.1,16 12,16Z</StreamGeometry>
        <StreamGeometry x:Key="IconImage">M19,3H5C3.9,3 3,3.9 3,5V19C3,20.1 3.9,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.9 20.1,3 19,3M8.5,8.5C7.67,8.5 7,7.83 7,7C7,6.17 7.67,5.5 8.5,5.5C9.33,5.5 10,6.17 10,7C10,7.83 9.33,8.5 8.5,8.5M19,18H5L8.5,13.5L11,16.51L14.5,12Z</StreamGeometry>
        <StreamGeometry x:Key="IconFilm">M18,4L20,8H17L15,4ZM10,4L12,8H9L7,4ZM4,4H5L7,8H4ZM4,10H20V18C20,19.1 19.1,20 18,20H6C4.9,20 4,19.1 4,18Z</StreamGeometry>
        <StreamGeometry x:Key="IconZoomOut">M9.5,3C5.91,3 3,5.91 3,9.5C3,13.09 5.91,16 9.5,16C11.11,16 12.59,15.41 13.73,14.44L14,14.71V15.5L19,20.49L20.49,19L15.5,14H14.71L14.44,13.73C15.41,12.59 16,11.11 16,9.5C16,5.91 13.09,3 9.5,3M6,8.5H13V10.5H6Z</StreamGeometry>
        <StreamGeometry x:Key="IconZoomIn">M9.5,3C5.91,3 3,5.91 3,9.5C3,13.09 5.91,16 9.5,16C11.11,16 12.59,15.41 13.73,14.44L14,14.71V15.5L19,20.49L20.49,19L15.5,14H14.71L14.44,13.73C15.41,12.59 16,11.11 16,9.5C16,5.91 13.09,3 9.5,3M8.5,6H10.5V8.5H13V10.5H10.5V13H8.5V10.5H6V8.5H8.5Z</StreamGeometry>
        <StreamGeometry x:Key="IconClose">M18.3,5.71L16.89,4.29L12,9.17L7.11,4.29L5.7,5.71L10.59,10.59L5.7,15.48L7.11,16.89L12,12L16.89,16.89L18.3,15.48L13.41,10.59Z</StreamGeometry>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>
        <Style Selector="TextBlock.secondary">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>
        <Style Selector="PathIcon.glyph">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar:pointerover">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.toolbar:disabled">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.toolbar:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.icon">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="36" />
        </Style>
        <Style Selector="Button.icon PathIcon.glyph">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.tile">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Border.tile:pointerover">
            <Setter Property="Background" Value="#08000000" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>
        <Style Selector="Border.tile.drop-target">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource SelectedBrush}" />
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="2" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="56,*,64" Background="{StaticResource AppBackgroundBrush}">
        <Border
            Grid.Row="0"
            Background="{StaticResource CommandBarBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,0,0,1"
            AutomationProperties.AutomationId="AppTitleBar">
            <Grid ColumnDefinitions="*,Auto" Margin="12,0,14,0">
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="2"
                    VerticalAlignment="Center">
                    <Button
                        Classes="toolbar icon"
                        ToolTip.Tip="上一個資料夾"
                        AutomationProperties.AutomationId="TitleBarBackButton"
                        Command="{Binding BackCommand}">
                        <PathIcon Classes="glyph" Data="{StaticResource IconBack}" />
                    </Button>
                    <Button
                        Classes="toolbar icon"
                        ToolTip.Tip="下一個資料夾"
                        AutomationProperties.AutomationId="TitleBarForwardButton"
                        Command="{Binding ForwardCommand}">
                        <PathIcon Classes="glyph" Data="{StaticResource IconForward}" />
                    </Button>
                    <Border Width="1" Height="24" Margin="5,0" Background="{StaticResource LineBrush}" />
                    <Button
                        Classes="toolbar icon"
                        ToolTip.Tip="重新整理"
                        AutomationProperties.AutomationId="TitleBarRefreshLibraryButton"
                        Command="{Binding RefreshLibraryCommand}">
                        <PathIcon Classes="glyph" Data="{StaticResource IconRefresh}" />
                    </Button>
                    <Button
                        Classes="toolbar"
                        ToolTip.Tip="選擇資料夾"
                        AutomationProperties.AutomationId="TitleBarOpenFolderButton"
                        Command="{Binding OpenFolderCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <PathIcon Classes="glyph" Data="{StaticResource IconFolder}" />
                            <TextBlock Text="選擇資料夾" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button
                        Classes="toolbar"
                        ToolTip.Tip="排序"
                        AutomationProperties.AutomationId="TitleBarSortMenuButton">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Text="↕" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SortLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="名稱由小到大" AutomationProperties.AutomationId="SortByNameAscendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="name-asc" />
                                <MenuItem Header="名稱由大到小" AutomationProperties.AutomationId="SortByNameDescendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="name-desc" />
                                <MenuItem Header="修改時間最舊到最新" AutomationProperties.AutomationId="SortByModifiedAtAscendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="modified-asc" />
                                <MenuItem Header="修改時間最新到最舊" AutomationProperties.AutomationId="SortByModifiedAtDescendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="modified-desc" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button
                        Classes="toolbar"
                        ToolTip.Tip="子資料夾"
                        AutomationProperties.AutomationId="TitleBarRecursiveModeToggle"
                        Command="{Binding ToggleIncludeSubfoldersCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <PathIcon Classes="glyph" Data="{StaticResource IconFolder}" />
                            <TextBlock Text="{Binding RecursiveModeLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button
                        Classes="toolbar icon"
                        ToolTip.Tip="更多"
                        AutomationProperties.AutomationId="TitleBarMoreActionsButton">
                        <PathIcon Classes="glyph" Data="{StaticResource IconMore}" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="將目前顯示項目轉為 JPG" AutomationProperties.AutomationId="TitleBarConvertVisibleButton" Command="{Binding ConvertVisibleCommand}" />
                                <MenuItem Header="清除同名非 JPG 檔案" AutomationProperties.AutomationId="TitleBarClearSameBasenameButton" Command="{Binding ClearSameBasenameCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid ColumnDefinitions="280,1,*">
                <Border
                    Grid.Column="0"
                    Padding="16,18,12,12"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,*">
                        <StackPanel Spacing="6" Margin="0,0,0,12">
                            <TextBlock Text="資料夾" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock
                                Text="{Binding CurrentFolderPath}"
                                Classes="secondary"
                                FontSize="12"
                                TextTrimming="CharacterEllipsis"
                                IsVisible="{Binding HasCurrentFolder}" />
                        </StackPanel>
                        <TreeView
                            x:Name="FolderTree"
                            Grid.Row="1"
                            AutomationProperties.AutomationId="FolderTree"
                            ItemsSource="{Binding FolderRoots}"
                            SelectionChanged="FolderTree_SelectionChanged">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate DataType="vm:FolderTreeItem" ItemsSource="{Binding Children}" x:DataType="vm:FolderTreeItem">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Classes="glyph" Data="{StaticResource IconFolder}" />
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="{StaticResource LineBrush}" />

                <Grid Grid.Column="2" RowDefinitions="82,*" Background="{StaticResource SurfaceBrush}">
                    <Border Grid.Row="0" Padding="20,18,24,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock
                                    Text="{Binding CurrentParentFolderName}"
                                    Classes="secondary"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="›"
                                    Classes="muted"
                                    FontSize="24"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding HasCurrentFolder}" />
                                <TextBlock
                                    Text="{Binding CurrentFolderName}"
                                    FontSize="24"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding LibraryItemCountText}"
                                Classes="muted"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <ListBox
                            x:Name="LibraryGrid"
                            AutomationProperties.AutomationId="LibraryGrid"
                            ItemsSource="{Binding LibraryItems}"
                            SelectionMode="Multiple"
                            SelectionChanged="LibraryGrid_SelectionChanged"
                            KeyDown="LibraryGrid_KeyDown"
                            Background="Transparent"
                            Padding="16,0,20,20"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemSpacing="12" LineSpacing="14" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="vm:LibraryTileItem" x:DataType="vm:LibraryTileItem">
                                    <Border
                                        Classes="tile"
                                        Classes.drop-target="{Binding IsDropRenameTarget}"
                                        Width="{Binding TileWidth}"
                                        MinHeight="{Binding TileHeight}"
                                        AutomationProperties.AutomationId="{Binding AutomationId}"
                                        AutomationProperties.Name="{Binding AutomationName}"
                                        Loaded="LibraryTile_Loaded"
                                        Unloaded="LibraryTile_Unloaded"
                                        Tapped="LibraryTile_Tapped"
                                        DoubleTapped="LibraryTile_DoubleTapped"
                                        RightTapped="LibraryTile_RightTapped"
                                        PointerPressed="LibraryTile_PointerPressed"
                                        PointerMoved="LibraryTile_PointerMoved"
                                        PointerReleased="LibraryTile_PointerReleased"
                                        PointerCaptureLost="LibraryTile_PointerCaptureLost">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <Border
                                                Height="{Binding TileHeight}"
                                                Background="{StaticResource TileFrameBrush}"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                ClipToBounds="True"
                                                CornerRadius="4">
                                                <Grid>
                                                    <Image Source="{Binding ThumbnailPath, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform" IsVisible="{Binding CanShowThumbnail}" />
                                                    <Panel
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding ShouldShowIcon}">
                                                        <PathIcon Classes="glyph muted" Data="{StaticResource IconFolder}" Width="42" Height="42" IsVisible="{Binding IsFolder}" />
                                                        <PathIcon Classes="glyph muted" Data="{StaticResource IconFilm}" Width="42" Height="42" IsVisible="{Binding IsAnimated}" />
                                                        <PathIcon Classes="glyph muted" Data="{StaticResource IconImage}" Width="42" Height="42" IsVisible="{Binding IsStillImage}" />
                                                    </Panel>
                                                </Grid>
                                            </Border>
                                            <TextBlock
                                                Grid.Row="1"
                                                Text="{Binding Name}"
                                                FontWeight="SemiBold"
                                                FontSize="14"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"
                                                MaxLines="2"
                                                Margin="4,8,4,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="14"
                            IsVisible="{Binding HasNoCurrentFolder}">
                            <TextBlock Text="尚未選擇資料夾" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <Button
                                Content="選擇資料夾"
                                HorizontalAlignment="Center"
                                AutomationProperties.AutomationId="EmptyStateOpenFolderButton"
                                Command="{Binding OpenFolderCommand}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <Border
                x:Name="LibraryDragPreviewOverlay"
                IsVisible="False"
                Background="{StaticResource AccentBrush}"
                CornerRadius="4"
                Padding="10,6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                ZIndex="20">
                <TextBlock x:Name="LibraryDragPreviewText" Foreground="White" />
            </Border>

        </Grid>

        <Border
            Grid.Row="2"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,1,0,0"
            Padding="24,8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <Border
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    Background="#FBFBFC"
                    CornerRadius="4"
                    Padding="14,9"
                    AutomationProperties.AutomationId="StatusBar">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border
                            Width="16"
                            Height="16"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="8"
                            VerticalAlignment="Center">
                            <TextBlock Text="i" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock
                            AutomationProperties.AutomationId="StatusInfoBar"
                            Text="{Binding StatusMessage}"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <PathIcon Classes="glyph secondary" Data="{StaticResource IconImage}" />
                    <TextBlock Text="{Binding ThumbnailSizeLabel}" Classes="secondary" VerticalAlignment="Center" />
                    <Slider
                        x:Name="ThumbnailSizeSlider"
                        AutomationProperties.AutomationId="ThumbnailSizeSlider"
                        Minimum="{Binding ThumbnailSizeMinimum}"
                        Maximum="{Binding ThumbnailSizeMaximum}"
                        TickFrequency="{Binding ThumbnailSizeStep}"
                        Value="{Binding ThumbnailSize, Mode=TwoWay}"
                        Width="160"
                        LostFocus="ThumbnailSizeSlider_CommitValue"
                        PointerCaptureLost="ThumbnailSizeSlider_CommitValue"
                        KeyUp="ThumbnailSizeSlider_KeyUp" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            x:Name="ViewerSurface"
            Grid.Row="0"
            Grid.RowSpan="3"
            IsVisible="False"
            Focusable="True"
            Background="{StaticResource ViewerCanvasBrush}"
            KeyDown="ViewerSurface_KeyDown"
            x:DataType="vm:ImageViewerWindowViewModel"
            ZIndex="50">
            <Grid RowDefinitions="56,*">
                <Border
                    Grid.Row="0"
                    Background="{StaticResource CommandBarBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,0,1"
                    IsVisible="{Binding IsChromeVisible}">
                    <Grid ColumnDefinitions="*,Auto,*">
                        <TextBlock
                            Text=" "
                            Width="1"
                            Height="1"
                            FontSize="1"
                            IsHitTestVisible="False"
                            AutomationProperties.AutomationId="ViewerSurface" />
                        <StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="2"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="ViewerTitleCommandBar">
                            <Button Classes="toolbar icon" ToolTip.Tip="上一張" AutomationProperties.AutomationId="ViewerPreviousButton" Command="{Binding PreviousCommand}">
                                <PathIcon Classes="glyph" Data="{StaticResource IconBack}" />
                            </Button>
                            <Button Classes="toolbar icon" ToolTip.Tip="下一張" AutomationProperties.AutomationId="ViewerNextButton" Command="{Binding NextCommand}">
                                <PathIcon Classes="glyph" Data="{StaticResource IconForward}" />
                            </Button>
                            <Border Width="1" Height="24" Margin="5,0" Background="{StaticResource LineBrush}" />
                            <Button Classes="toolbar icon" ToolTip.Tip="縮小" AutomationProperties.AutomationId="ViewerZoomOutButton" Command="{Binding ZoomOutCommand}">
                                <PathIcon Classes="glyph" Data="{StaticResource IconZoomOut}" />
                            </Button>
                            <Button Classes="toolbar icon" ToolTip.Tip="重設" AutomationProperties.AutomationId="ViewerResetZoomButton" Command="{Binding ResetZoomCommand}">
                                <PathIcon Classes="glyph" Data="{StaticResource IconRefresh}" />
                            </Button>
                            <Button Classes="toolbar icon" ToolTip.Tip="放大" AutomationProperties.AutomationId="ViewerZoomInButton" Command="{Binding ZoomInCommand}">
                                <PathIcon Classes="glyph" Data="{StaticResource IconZoomIn}" />
                            </Button>
                            <Border Width="1" Height="24" Margin="5,0" Background="{StaticResource LineBrush}" />
                            <Button Classes="toolbar icon" ToolTip.Tip="關閉" AutomationProperties.AutomationId="ViewerCloseButton" Click="CloseViewer_Click">
                                <PathIcon Classes="glyph" Data="{StaticResource IconClose}" />
                            </Button>
                        </StackPanel>
                        <TextBlock
                            Grid.Column="2"
                            Text="{Binding CurrentImageName}"
                            Classes="secondary"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="16,0,18,0"
                            TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>
                <Grid
                    x:Name="ViewerImageSurface"
                    Grid.Row="1"
                    ClipToBounds="True"
                    Background="{StaticResource ViewerCanvasBrush}"
                    SizeChanged="ViewerImageSurface_SizeChanged"
                    PointerWheelChanged="ViewerImageSurface_PointerWheelChanged"
                    PointerPressed="ViewerImageSurface_PointerPressed"
                    PointerMoved="ViewerImageSurface_PointerMoved"
                    PointerReleased="ViewerImageSurface_PointerReleased"
                    PointerCaptureLost="ViewerImageSurface_PointerCaptureLost">
                    <Image
                        x:Name="ViewerImage"
                        AutomationProperties.AutomationId="ViewerImage"
                        AutomationProperties.Name="{Binding CurrentImageName}"
                        Source="{Binding CurrentImageSourcePath, Converter={StaticResource ImagePathConverter}}"
                        Stretch="Uniform"
                        IsVisible="{Binding IsImageVisible}"
                        RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                                <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}" />
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <TextBlock
                        Text="{Binding UnsupportedMessage}"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        FontSize="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsUnsupportedAnimatedImage}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
