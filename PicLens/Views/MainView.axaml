<UserControl
    x:Class="PicLens.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PicLens.Converters"
    xmlns:ic="using:FluentIcons.Avalonia"
    xmlns:ir="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ItemsRepeater"
    xmlns:irlayout="clr-namespace:Avalonia.Layout;assembly=Avalonia.Controls.ItemsRepeater"
    xmlns:vm="using:PicLens.ViewModels"
    x:DataType="vm:MainPageViewModel"
    x:Name="Root"
    Focusable="True">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F5F7" />
        <SolidColorBrush x:Key="CommandBarBrush" Color="#FBFBFC" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#F8F9FB" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TileFrameBrush" Color="#ECEEF2" />
        <SolidColorBrush x:Key="LineBrush" Color="#E2E5EA" />
        <SolidColorBrush x:Key="StrongLineBrush" Color="#D5D9E1" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#20242B" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5F6672" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#626B78" />
        <SolidColorBrush x:Key="HoverBrush" Color="#ECEFF4" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#E7EEFF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4968E8" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#3F5DD3" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#344FC4" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#EDF1FF" />
        <SolidColorBrush x:Key="AccentSoftPressedBrush" Color="#DCE4FF" />
        <SolidColorBrush x:Key="ScopeActiveBorderBrush" Color="#B9C7FF" />
        <SolidColorBrush x:Key="SearchBackgroundBrush" Color="#F0F2F5" />
        <SolidColorBrush x:Key="LibraryBackgroundBrush" Color="#FDFDFE" />
        <SolidColorBrush x:Key="ViewerOverlayBrush" Color="#F2101217" />
        <SolidColorBrush x:Key="ViewerCanvasBrush" Color="#11141A" />
        <SolidColorBrush x:Key="ViewerChromeBrush" Color="#E61D2129" />
        <SolidColorBrush x:Key="ViewerBorderBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="ViewerSeparatorBrush" Color="#40FFFFFF" />
        <SolidColorBrush x:Key="ViewerSecondaryTextBrush" Color="#AAB2C0" />
        <SolidColorBrush x:Key="ViewerHoverBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="ViewerPressedBrush" Color="#4DFFFFFF" />
        <converters:ImagePathConverter x:Key="ImagePathConverter" />

        <DataTemplate x:Key="LibraryTileTemplate" DataType="vm:LibraryTileItem" x:DataType="vm:LibraryTileItem">
            <Border
                x:Name="LibraryTile"
                Classes="tile"
                Classes.selected="{Binding IsSelected}"
                Classes.drop-target="{Binding IsDropRenameTarget}"
                MinWidth="{ReflectionBinding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                MinHeight="{ReflectionBinding DataContext.LibraryTileLayoutHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                AutomationProperties.AutomationId="{Binding AutomationId}"
                AutomationProperties.Name="{Binding AutomationName}"
                AutomationProperties.ControlTypeOverride="ListItem"
                Focusable="True"
                KeyDown="LibraryTile_KeyDown"
                Tapped="LibraryTile_Tapped"
                DoubleTapped="LibraryTile_DoubleTapped"
                RightTapped="LibraryTile_RightTapped"
                PointerPressed="LibraryTile_PointerPressed"
                PointerMoved="LibraryTile_PointerMoved"
                PointerReleased="LibraryTile_PointerReleased"
                PointerCaptureLost="LibraryTile_PointerCaptureLost">
                <ToolTip.Tip>
                    <TextBlock
                        x:DataType="vm:LibraryTileItem"
                        DataContext="{Binding #LibraryTile.DataContext}"
                        Text="{Binding Name}"
                        TextWrapping="Wrap"
                        MaxWidth="720" />
                </ToolTip.Tip>
                <Panel>
                    <Grid RowDefinitions="Auto,Auto" IsVisible="{ReflectionBinding DataContext.IsGridViewMode, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <Border
                            Grid.Row="0"
                            Background="{StaticResource TileFrameBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            CornerRadius="10"
                            Height="{ReflectionBinding DataContext.LibraryThumbnailHeight, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Grid ClipToBounds="True">
                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource ImagePathConverter}, ConverterParameter=cache}" Stretch="UniformToFill" IsVisible="{Binding CanShowThumbnail}" />
                                <Panel HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding ShouldShowIcon}">
                                    <ic:FluentIcon Classes="glyph muted" Icon="Folder" IconVariant="Regular" IconSize="Size48" IsVisible="{Binding IsFolder}" />
                                    <ic:FluentIcon Classes="glyph muted" Icon="Filmstrip" IconVariant="Regular" IconSize="Size48" IsVisible="{Binding IsAnimated}" />
                                    <ic:FluentIcon Classes="glyph muted" Icon="Image" IconVariant="Regular" IconSize="Size48" IsVisible="{Binding IsStillImage}" />
                                </Panel>
                                <Border Classes="check-dot" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" IsVisible="{Binding IsSelected}">
                                    <TextBlock Text="✓" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock
                            Grid.Row="1"
                            Text="{Binding Name}"
                            FontWeight="SemiBold"
                            FontSize="13"
                            TextWrapping="Wrap"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="2"
                            Margin="3,9,3,0" />
                    </Grid>

                    <Grid ColumnDefinitions="88,*" ColumnSpacing="14" MinHeight="100" IsVisible="{ReflectionBinding DataContext.IsListViewMode, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <Border
                            Background="{StaticResource TileFrameBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            CornerRadius="10"
                            Width="96"
                            Height="68"
                            VerticalAlignment="Center">
                            <Grid ClipToBounds="True">
                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource ImagePathConverter}, ConverterParameter=cache}" Stretch="UniformToFill" IsVisible="{Binding CanShowThumbnail}" />
                                <Panel HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding ShouldShowIcon}">
                                    <ic:FluentIcon Classes="glyph muted" Icon="Folder" IconVariant="Regular" IconSize="Size32" IsVisible="{Binding IsFolder}" />
                                    <ic:FluentIcon Classes="glyph muted" Icon="Filmstrip" IconVariant="Regular" IconSize="Size32" IsVisible="{Binding IsAnimated}" />
                                    <ic:FluentIcon Classes="glyph muted" Icon="Image" IconVariant="Regular" IconSize="Size32" IsVisible="{Binding IsStillImage}" />
                                </Panel>
                                <Border Classes="check-dot" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6" IsVisible="{Binding IsSelected}">
                                    <TextBlock Text="✓" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding KindLabel}" Classes="caption" />
                        </StackPanel>
                    </Grid>
                </Panel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>
        <Style Selector="TextBlock.secondary">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>
        <Style Selector="ic|FluentIcon.glyph">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="ic|FluentIcon.muted">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
        </Style>
        <Style Selector="Button.toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SelectedBrush}" />
        </Style>
        <Style Selector="Button.viewer-toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ViewerHoverBrush}" />
        </Style>
        <Style Selector="Button.viewer-toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ViewerPressedBrush}" />
        </Style>
        <Style Selector="Button.toolbar:disabled">
            <Setter Property="Opacity" Value="0.38" />
        </Style>
        <Style Selector="Button.icon">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
        </Style>
        <Style Selector="Button.icon ic|FluentIcon.glyph">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentPressedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentPressedBrush}" />
        </Style>
        <Style Selector="Button.pill">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style Selector="Button.pill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
        </Style>
        <Style Selector="Button.pill:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SelectedBrush}" />
        </Style>
        <Style Selector="Button.scope-toggle.active">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ScopeActiveBorderBrush}" />
        </Style>
        <Style Selector="Button.scope-toggle.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SelectedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ScopeActiveBorderBrush}" />
        </Style>
        <Style Selector="Button.scope-toggle.active:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentSoftPressedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ScopeActiveBorderBrush}" />
        </Style>
        <Style Selector="Button.view-toggle:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        </Style>
        <Style Selector="Button.view-toggle:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        </Style>
        <Style Selector="Button.view-toggle.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        </Style>
        <Style Selector="Button.view-toggle.active:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SelectedBrush}" />
        </Style>
        <Style Selector="Button.view-toggle.active:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentSoftPressedBrush}" />
        </Style>
        <Style Selector="Border.segmented">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="2" />
        </Style>
        <Style Selector="Border.tile">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style Selector="Border.tile:pointerover">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrongLineBrush}" />
        </Style>
        <Style Selector="Border.tile.selected">
            <Setter Property="Background" Value="{StaticResource SelectedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style Selector="Border.tile:focus">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Border.tile.drop-target">
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Border.check-dot">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="TextBox.search">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.search-shell">
            <Setter Property="Background" Value="{StaticResource SearchBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="9,0,3,0" />
        </Style>
        <Style Selector="Border.search-shell:pointerover">
            <Setter Property="BorderBrush" Value="{StaticResource StrongLineBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="64,*,44" Background="{StaticResource AppBackgroundBrush}">
        <Border
            Grid.Row="0"
            Background="{StaticResource CommandBarBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,0,0,1"
            AutomationProperties.AccessibilityView="Control"
            AutomationProperties.ControlTypeOverride="Pane"
            AutomationProperties.AutomationId="AppTitleBar">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="18,0" ColumnSpacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="10" Background="{StaticResource AccentBrush}">
                        <ic:FluentIcon Icon="ImageMultiple" IconVariant="Regular" IconSize="Size20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="PicLens" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button Classes="toolbar icon" ToolTip.Tip="收合側欄" AutomationProperties.Name="收合側欄" AutomationProperties.AutomationId="TitleBarSidebarToggleButton" Command="{Binding ToggleSidebarCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="PanelLeft" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                    <Button Classes="toolbar icon" ToolTip.Tip="上一個資料夾" AutomationProperties.Name="上一個資料夾" AutomationProperties.AutomationId="TitleBarBackButton" Command="{Binding BackCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="ArrowLeft" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                    <Button Classes="toolbar icon" ToolTip.Tip="下一個資料夾" AutomationProperties.Name="下一個資料夾" AutomationProperties.AutomationId="TitleBarForwardButton" Command="{Binding ForwardCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="ArrowRight" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                    <Button Classes="toolbar icon" ToolTip.Tip="重新整理" AutomationProperties.Name="重新整理圖庫" AutomationProperties.AutomationId="TitleBarRefreshLibraryButton" Command="{Binding RefreshLibraryCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="ArrowClockwise" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                </StackPanel>

                <Border Grid.Column="2" Classes="search-shell" MinWidth="130" MaxWidth="430" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4">
                        <ic:FluentIcon Classes="glyph muted" Icon="Search" IconVariant="Regular" IconSize="Size16" />
                        <TextBox
                            Grid.Column="1"
                            Classes="search"
                            PlaceholderText="搜尋目前 Library"
                            AutomationProperties.Name="搜尋目前 Library"
                            AutomationProperties.AutomationId="LibrarySearchBox"
                            Text="{Binding SearchQuery, Mode=TwoWay}" />
                        <Button Grid.Column="2" Classes="toolbar icon" Width="32" Height="32" ToolTip.Tip="清除搜尋" AutomationProperties.Name="清除搜尋" AutomationProperties.AutomationId="LibrarySearchClearButton" IsVisible="{Binding HasSearchQuery}" Command="{Binding ClearSearchCommand}">
                            <ic:FluentIcon Classes="glyph" Icon="Dismiss" IconVariant="Regular" IconSize="Size16" />
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="primary" ToolTip.Tip="選擇資料夾" AutomationProperties.AutomationId="TitleBarOpenFolderButton" Command="{Binding OpenFolderCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <ic:FluentIcon Classes="glyph" Icon="FolderOpen" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                            <TextBlock Text="開啟資料夾" Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar icon" ToolTip.Tip="更多操作" AutomationProperties.Name="更多操作" AutomationProperties.AutomationId="TitleBarMoreActionsButton">
                        <ic:FluentIcon Classes="glyph" Icon="MoreVertical" IconVariant="Regular" IconSize="Size20" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="將目前顯示項目轉為 JPG" AutomationProperties.AutomationId="TitleBarConvertVisibleButton" Command="{Binding ConvertVisibleCommand}" />
                                <MenuItem Header="清除同名非 JPG 檔案" AutomationProperties.AutomationId="TitleBarClearSameBasenameButton" Command="{Binding ClearSameBasenameCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,4,*" Margin="12">
            <Border
                Grid.Column="0"
                Width="248"
                Padding="14,16"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="12"
                IsVisible="{Binding IsSidebarOpen}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="資料夾" FontSize="13" FontWeight="SemiBold" Classes="secondary" />
                    <TreeView
                        x:Name="FolderTree"
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Background="Transparent"
                        BorderThickness="0"
                        AutomationProperties.AutomationId="FolderTree"
                        ItemsSource="{Binding FolderRoots}"
                        SelectionChanged="FolderTree_SelectionChanged">
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.Styles>
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate DataType="vm:FolderTreeItem" ItemsSource="{Binding Children}" x:DataType="vm:FolderTreeItem">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Classes="glyph muted" Icon="Folder" IconVariant="Regular" IconSize="Size20" />
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="Transparent" IsVisible="{Binding IsSidebarOpen}" />

            <Border Grid.Column="2" Margin="8,0,0,0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="20,14,16,13">
                        <Grid RowDefinitions="Auto,Auto">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock Text="{Binding CurrentParentFolderName}" Classes="secondary" FontSize="14" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="›" Classes="muted" FontSize="16" IsVisible="{Binding HasCurrentFolder}" />
                                    <TextBlock Text="{Binding CurrentFolderName}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding LibraryItemCountText}" Classes="secondary" VerticalAlignment="Center" />
                                    <TextBlock Text="•" Classes="muted" IsVisible="{Binding HasSearchQuery}" />
                                    <TextBlock Text="{Binding SearchQuery, StringFormat='搜尋「{0}」'}" Classes="caption" VerticalAlignment="Center" IsVisible="{Binding HasSearchQuery}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button Classes="pill" ToolTip.Tip="排序 Library" AutomationProperties.AutomationId="TitleBarSortMenuButton">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <TextBlock Text="{Binding SortLabel}" VerticalAlignment="Center" />
                                            <ic:FluentIcon Classes="glyph muted" Icon="ChevronDown" IconVariant="Regular" IconSize="Size16" />
                                        </StackPanel>
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuItem Header="名稱由小到大" AutomationProperties.AutomationId="SortByNameAscendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="name-asc" />
                                                <MenuItem Header="名稱由大到小" AutomationProperties.AutomationId="SortByNameDescendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="name-desc" />
                                                <MenuItem Header="修改時間最舊到最新" AutomationProperties.AutomationId="SortByModifiedAtAscendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="modified-asc" />
                                                <MenuItem Header="修改時間最新到最舊" AutomationProperties.AutomationId="SortByModifiedAtDescendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="modified-desc" />
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                    <Button Classes="pill scope-toggle" Classes.active="{Binding IncludeSubfolders}" ToolTip.Tip="切換子資料夾顯示範圍" AutomationProperties.AutomationId="TitleBarRecursiveModeToggle" Command="{Binding ToggleIncludeSubfoldersCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <ic:FluentIcon Classes="glyph" Icon="Folder" IconVariant="Regular" IconSize="Size16" />
                                            <TextBlock Text="{Binding RecursiveModeLabel}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Border Classes="segmented">
                                        <StackPanel Orientation="Horizontal" Spacing="0">
                                            <Button Classes="toolbar icon view-toggle" Classes.active="{Binding IsGridViewMode}" ToolTip.Tip="格狀檢視" AutomationProperties.Name="格狀檢視" AutomationProperties.AutomationId="TitleBarGridViewButton" Command="{Binding SetViewModeCommand}" CommandParameter="grid">
                                                <ic:FluentIcon Classes="glyph" Icon="LayoutColumnTwo" IconVariant="Regular" IconSize="Size20" />
                                            </Button>
                                            <Button Classes="toolbar icon view-toggle" Classes.active="{Binding IsListViewMode}" ToolTip.Tip="列表檢視" AutomationProperties.Name="列表檢視" AutomationProperties.AutomationId="TitleBarListViewButton" Command="{Binding SetViewModeCommand}" CommandParameter="list">
                                                <ic:FluentIcon Classes="glyph" Icon="TextBulletListSquare" IconVariant="Regular" IconSize="Size20" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Background="{StaticResource LibraryBackgroundBrush}">
                        <ScrollViewer
                            x:Name="LibraryGrid"
                            AutomationProperties.AutomationId="LibraryGrid"
                            Focusable="True"
                            KeyDown="LibraryGrid_KeyDown"
                            HorizontalScrollBarVisibility="Disabled"
                            IsScrollInertiaEnabled="True">
                            <ScrollViewer.Transitions>
                                <Transitions>
                                    <VectorTransition Property="Offset" Duration="0:0:0.14" />
                                </Transitions>
                            </ScrollViewer.Transitions>
                            <StackPanel Spacing="22" Margin="18,18,18,24">
                                <StackPanel Spacing="10" IsVisible="{Binding HasFolderLibraryItems}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="資料夾" FontSize="14" FontWeight="SemiBold" />
                                        <Border Background="{StaticResource HoverBrush}" CornerRadius="8" Padding="7,2">
                                            <TextBlock Text="{Binding FolderItemCountText}" Classes="caption" />
                                        </Border>
                                    </StackPanel>
                                    <ir:ItemsRepeater ItemsSource="{Binding FolderLibraryItems}" ItemTemplate="{StaticResource LibraryTileTemplate}" ElementPrepared="LibraryItemsRepeater_ElementPrepared" ElementClearing="LibraryItemsRepeater_ElementClearing">
                                        <ir:ItemsRepeater.Layout>
                                            <irlayout:UniformGridLayout MinItemWidth="{Binding LibraryLayoutMinItemWidth}" MinItemHeight="{Binding LibraryTileLayoutHeight}" MinRowSpacing="12" MinColumnSpacing="10" />
                                        </ir:ItemsRepeater.Layout>
                                    </ir:ItemsRepeater>
                                </StackPanel>

                                <StackPanel Spacing="10" IsVisible="{Binding HasImageLibraryItems}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="圖片" FontSize="14" FontWeight="SemiBold" />
                                        <Border Background="{StaticResource HoverBrush}" CornerRadius="8" Padding="7,2">
                                            <TextBlock Text="{Binding ImageItemCountText}" Classes="caption" />
                                        </Border>
                                    </StackPanel>
                                    <ir:ItemsRepeater ItemsSource="{Binding ImageLibraryItems}" ItemTemplate="{StaticResource LibraryTileTemplate}" ElementPrepared="LibraryItemsRepeater_ElementPrepared" ElementClearing="LibraryItemsRepeater_ElementClearing">
                                        <ir:ItemsRepeater.Layout>
                                            <irlayout:UniformGridLayout MinItemWidth="{Binding LibraryLayoutMinItemWidth}" MinItemHeight="{Binding LibraryTileLayoutHeight}" MinRowSpacing="12" MinColumnSpacing="10" />
                                        </ir:ItemsRepeater.Layout>
                                    </ir:ItemsRepeater>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="13" MaxWidth="360" IsVisible="{Binding HasNoCurrentFolder}">
                            <Border Width="64" Height="64" CornerRadius="20" Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Center">
                                <ic:FluentIcon Icon="FolderOpen" IconVariant="Regular" IconSize="Size32" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="從一個資料夾開始" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="選擇圖片資料夾後，就能在同一個工作區瀏覽、整理與快速檢視。" Classes="secondary" TextAlignment="Center" TextWrapping="Wrap" />
                            <Button Classes="primary" HorizontalAlignment="Center" AutomationProperties.AutomationId="EmptyStateOpenFolderButton" Command="{Binding OpenFolderCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <ic:FluentIcon Classes="glyph" Icon="FolderOpen" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                                    <TextBlock Text="選擇資料夾" Foreground="White" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" IsVisible="{Binding HasEmptyFolder}">
                            <Border Width="52" Height="52" CornerRadius="18" Background="{StaticResource HoverBrush}" HorizontalAlignment="Center">
                                <ic:FluentIcon Icon="ImageMultiple" IconVariant="Regular" IconSize="Size24" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="這個資料夾沒有支援的圖片" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="選擇其他資料夾，或開啟含子資料夾模式。" Classes="secondary" HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" IsVisible="{Binding HasNoSearchResults}">
                            <Border Width="52" Height="52" CornerRadius="18" Background="{StaticResource HoverBrush}" HorizontalAlignment="Center">
                                <ic:FluentIcon Icon="Search" IconVariant="Regular" IconSize="Size24" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="沒有符合條件的項目" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="清除搜尋，或換一個關鍵字。" Classes="secondary" HorizontalAlignment="Center" />
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" MaxWidth="460" IsVisible="{Binding HasLibraryError}">
                            <ic:FluentIcon Icon="ErrorCircle" IconVariant="Regular" IconSize="Size28" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="無法載入資料夾" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding LibraryErrorMessage}" Classes="secondary" AutomationProperties.LiveSetting="Assertive" TextAlignment="Center" TextWrapping="Wrap" />
                            <Button Classes="primary" Content="重試" HorizontalAlignment="Center" Command="{Binding RefreshLibraryCommand}" />
                        </StackPanel>

                        <Border Background="{StaticResource LibraryBackgroundBrush}" IsVisible="{Binding IsLibraryLoading}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                <ProgressBar Width="200" IsIndeterminate="True" />
                                <TextBlock Text="正在載入圖庫…" Classes="secondary" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border
                x:Name="LibraryDragPreviewOverlay"
                IsVisible="False"
                Background="{StaticResource AccentBrush}"
                CornerRadius="10"
                Padding="11,7"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                ZIndex="20">
                <TextBlock x:Name="LibraryDragPreviewText" Foreground="White" FontWeight="SemiBold" />
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource CommandBarBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="20,5">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Orientation="Horizontal" Spacing="9" AutomationProperties.AutomationId="StatusBar" VerticalAlignment="Center">
                    <Border Width="8" Height="8" Background="{StaticResource AccentBrush}" CornerRadius="4" VerticalAlignment="Center" />
                    <TextBlock AutomationProperties.AutomationId="StatusInfoBar" AutomationProperties.LiveSetting="Polite" Text="{Binding StatusMessage}" Classes="secondary" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock Text="•" Classes="muted" IsVisible="{Binding HasSelectedImages}" />
                    <TextBlock Text="{Binding SelectedSummaryText}" FontSize="12" FontWeight="SemiBold" IsVisible="{Binding HasSelectedImages}" />
                    <ProgressBar Width="72" Height="3" IsIndeterminate="True" IsVisible="{Binding IsFileOperationActive}" />
                    <Button Classes="toolbar" Content="取消" AutomationProperties.Name="取消目前檔案操作" IsVisible="{Binding IsFileOperationActive}" Command="{Binding CancelFileOperationCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
                    <ic:FluentIcon Classes="glyph muted" Icon="ImageMultiple" IconVariant="Regular" IconSize="Size16" />
                    <TextBlock Text="{Binding ThumbnailSizeLabel}" Classes="caption" VerticalAlignment="Center" />
                    <Slider
                        x:Name="ThumbnailSizeSlider"
                        AutomationProperties.AutomationId="ThumbnailSizeSlider"
                        AutomationProperties.Name="縮圖大小"
                        Minimum="{Binding ThumbnailSizeMinimum}"
                        Maximum="{Binding ThumbnailSizeMaximum}"
                        TickFrequency="{Binding ThumbnailSizeStep}"
                        Value="{Binding ThumbnailSize, Mode=TwoWay}"
                        Width="140"
                        VerticalAlignment="Center"
                        LostFocus="ThumbnailSizeSlider_CommitValue"
                        PointerCaptureLost="ThumbnailSizeSlider_CommitValue"
                        KeyUp="ThumbnailSizeSlider_KeyUp">
                        <Slider.Resources>
                            <GridLength x:Key="SliderPreContentMargin">6</GridLength>
                            <GridLength x:Key="SliderPostContentMargin">6</GridLength>
                        </Slider.Resources>
                    </Slider>
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            x:Name="ViewerSurface"
            Grid.Row="0"
            Grid.RowSpan="3"
            IsVisible="False"
            Focusable="True"
            Background="{StaticResource ViewerOverlayBrush}"
            KeyDown="ViewerSurface_KeyDown"
            x:DataType="vm:ImageViewerWindowViewModel"
            AutomationProperties.AutomationId="ViewerSurface"
            ZIndex="50">
            <Grid RowDefinitions="64,*,Auto">
                <Border Grid.Row="0" Background="{StaticResource ViewerChromeBrush}" BorderBrush="{StaticResource ViewerBorderBrush}" BorderThickness="0,0,0,1" Padding="20,0">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Width="34" Height="34" CornerRadius="10" Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                            <ic:FluentIcon Icon="Image" IconVariant="Regular" IconSize="Size20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentImageName}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="圖片檢視器" Foreground="{StaticResource ViewerSecondaryTextBrush}" FontSize="11" />
                        </StackPanel>
                        <Button Grid.Column="2" Classes="toolbar viewer-toolbar icon" ToolTip.Tip="關閉" AutomationProperties.Name="關閉圖片檢視器" AutomationProperties.AutomationId="ViewerCloseButton" Click="CloseViewer_Click">
                            <ic:FluentIcon Classes="glyph" Icon="Dismiss" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                        </Button>
                    </Grid>
                </Border>

                <Grid
                    x:Name="ViewerImageSurface"
                    Grid.Row="1"
                    ClipToBounds="True"
                    Background="{StaticResource ViewerCanvasBrush}"
                    SizeChanged="ViewerImageSurface_SizeChanged"
                    PointerWheelChanged="ViewerImageSurface_PointerWheelChanged"
                    PointerPressed="ViewerImageSurface_PointerPressed"
                    PointerMoved="ViewerImageSurface_PointerMoved"
                    PointerReleased="ViewerImageSurface_PointerReleased"
                    PointerCaptureLost="ViewerImageSurface_PointerCaptureLost">
                    <Image
                        x:Name="ViewerImage"
                        Margin="24"
                        AutomationProperties.AutomationId="ViewerImage"
                        AutomationProperties.Name="{Binding CurrentImageName}"
                        Stretch="Uniform"
                        IsVisible="{Binding IsImageVisible}"
                        RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                                <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}" />
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <TextBlock Text="{Binding UnsupportedMessage}" Foreground="White" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsUnsupportedAnimatedImage}" />
                </Grid>

                <Border Grid.Row="2" Background="{StaticResource ViewerCanvasBrush}" Padding="0,0,0,18">
                    <Border Background="{StaticResource ViewerChromeBrush}" BorderBrush="{StaticResource ViewerBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="8" HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="4" AutomationProperties.AutomationId="ViewerTitleCommandBar">
                            <Button Classes="toolbar viewer-toolbar" ToolTip.Tip="上一張" AutomationProperties.AutomationId="ViewerPreviousButton" Command="{Binding PreviousCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ic:FluentIcon Classes="glyph" Icon="ArrowLeft" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                                    <TextBlock Text="上一張" Foreground="White" />
                                </StackPanel>
                            </Button>
                            <Border Width="1" Height="20" Background="{StaticResource ViewerSeparatorBrush}" Margin="5,0" />
                            <Button Classes="toolbar viewer-toolbar icon" ToolTip.Tip="縮小" AutomationProperties.Name="縮小圖片" AutomationProperties.AutomationId="ViewerZoomOutButton" Command="{Binding ZoomOutCommand}">
                                <ic:FluentIcon Classes="glyph" Icon="ZoomOut" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                            </Button>
                            <Button Classes="toolbar viewer-toolbar icon" ToolTip.Tip="重設" AutomationProperties.Name="重設圖片縮放" AutomationProperties.AutomationId="ViewerResetZoomButton" Command="{Binding ResetZoomCommand}">
                                <ic:FluentIcon Classes="glyph" Icon="ArrowClockwise" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                            </Button>
                            <Button Classes="toolbar viewer-toolbar icon" ToolTip.Tip="放大" AutomationProperties.Name="放大圖片" AutomationProperties.AutomationId="ViewerZoomInButton" Command="{Binding ZoomInCommand}">
                                <ic:FluentIcon Classes="glyph" Icon="ZoomIn" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                            </Button>
                            <Border Width="1" Height="20" Background="{StaticResource ViewerSeparatorBrush}" Margin="5,0" />
                            <Button Classes="toolbar viewer-toolbar" ToolTip.Tip="下一張" AutomationProperties.AutomationId="ViewerNextButton" Command="{Binding NextCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="下一張" Foreground="White" />
                                    <ic:FluentIcon Classes="glyph" Icon="ArrowRight" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
