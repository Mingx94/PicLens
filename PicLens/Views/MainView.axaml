<UserControl
    x:Class="PicLens.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PicLens.Converters"
    xmlns:ic="using:FluentIcons.Avalonia"
    xmlns:ir="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ItemsRepeater"
    xmlns:irlayout="clr-namespace:Avalonia.Layout;assembly=Avalonia.Controls.ItemsRepeater"
    xmlns:vm="using:PicLens.ViewModels"
    x:DataType="vm:MainPageViewModel"
    x:Name="Root"
    Focusable="True">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FAF9F6" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#FFFDFC" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#F6FBF8" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TileFrameBrush" Color="#F3F7F8" />
        <SolidColorBrush x:Key="LineBrush" Color="#E5E8EA" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#26302F" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5E6A67" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#87918D" />
        <SolidColorBrush x:Key="HoverBrush" Color="#EEF7F3" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#DDF4EC" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2CB89E" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E7F8F4" />
        <SolidColorBrush x:Key="SkyBrush" Color="#EAF5FF" />
        <SolidColorBrush x:Key="CoralBrush" Color="#F36F5B" />
        <SolidColorBrush x:Key="ViewerCanvasBrush" Color="#F8F7F3" />
        <converters:ImagePathConverter x:Key="ImagePathConverter" />

        <DataTemplate x:Key="LibraryTileTemplate" DataType="vm:LibraryTileItem" x:DataType="vm:LibraryTileItem">
            <Border
                x:Name="LibraryTile"
                Classes="tile"
                Classes.selected="{Binding IsSelected}"
                Classes.drop-target="{Binding IsDropRenameTarget}"
                MinWidth="{Binding TileWidth}"
                MinHeight="{Binding TileDisplayHeight}"
                AutomationProperties.AutomationId="{Binding AutomationId}"
                AutomationProperties.Name="{Binding AutomationName}"
                Loaded="LibraryTile_Loaded"
                Unloaded="LibraryTile_Unloaded"
                Tapped="LibraryTile_Tapped"
                DoubleTapped="LibraryTile_DoubleTapped"
                RightTapped="LibraryTile_RightTapped"
                PointerPressed="LibraryTile_PointerPressed"
                PointerMoved="LibraryTile_PointerMoved"
                PointerReleased="LibraryTile_PointerReleased"
                PointerCaptureLost="LibraryTile_PointerCaptureLost">
                <ToolTip.Tip>
                    <TextBlock
                        x:DataType="vm:LibraryTileItem"
                        DataContext="{Binding #LibraryTile.DataContext}"
                        Text="{Binding Name}"
                        TextWrapping="Wrap"
                        MaxWidth="720" />
                </ToolTip.Tip>
                <Panel>
                    <Grid RowDefinitions="Auto,Auto" IsVisible="{Binding IsGridViewMode}">
                        <Border
                            Grid.Row="0"
                            Background="{StaticResource TileFrameBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            CornerRadius="8"
                            Height="{Binding TileHeight}">
                            <Grid ClipToBounds="True">
                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource ImagePathConverter}, ConverterParameter=cache}" Stretch="UniformToFill" IsVisible="{Binding CanShowThumbnail}" />
                                <Panel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding ShouldShowIcon}">
                                    <ic:FluentIcon Classes="glyph muted" Icon="Folder" IconVariant="Regular" IconSize="Size48" IsVisible="{Binding IsFolder}" />
                                    <ic:FluentIcon Classes="glyph muted" Icon="Filmstrip" IconVariant="Regular" IconSize="Size48" IsVisible="{Binding IsAnimated}" />
                                    <ic:FluentIcon Classes="glyph muted" Icon="Image" IconVariant="Regular" IconSize="Size48" IsVisible="{Binding IsStillImage}" />
                                </Panel>
                                <Border
                                    Classes="check-dot"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    IsVisible="{Binding IsSelected}">
                                    <TextBlock Text="✓" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock
                            Grid.Row="1"
                            Text="{Binding Name}"
                            FontWeight="SemiBold"
                            FontSize="14"
                            TextWrapping="Wrap"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="2"
                            Margin="2,9,2,0" />
                    </Grid>
                    <Grid
                        ColumnDefinitions="96,*"
                        ColumnSpacing="14"
                        MinHeight="{Binding TileDisplayHeight}"
                        IsVisible="{Binding IsListViewMode}">
                        <Border
                            Background="{StaticResource TileFrameBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            CornerRadius="8"
                            Width="{Binding ListThumbnailWidth}"
                            Height="{Binding ListThumbnailHeight}"
                            VerticalAlignment="Center">
                            <Grid ClipToBounds="True">
                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource ImagePathConverter}, ConverterParameter=cache}" Stretch="UniformToFill" IsVisible="{Binding CanShowThumbnail}" />
                                <Panel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding ShouldShowIcon}">
                                    <ic:FluentIcon Classes="glyph muted" Icon="Folder" IconVariant="Regular" IconSize="Size32" IsVisible="{Binding IsFolder}" />
                                    <ic:FluentIcon Classes="glyph muted" Icon="Filmstrip" IconVariant="Regular" IconSize="Size32" IsVisible="{Binding IsAnimated}" />
                                    <ic:FluentIcon Classes="glyph muted" Icon="Image" IconVariant="Regular" IconSize="Size32" IsVisible="{Binding IsStillImage}" />
                                </Panel>
                                <Border
                                    Classes="check-dot"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="6"
                                    IsVisible="{Binding IsSelected}">
                                    <TextBlock Text="✓" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding Name}"
                            FontWeight="SemiBold"
                            FontSize="14"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center" />
                    </Grid>
                </Panel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>
        <Style Selector="TextBlock.secondary">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>
        <Style Selector="ic|FluentIcon.glyph">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="ic|FluentIcon.muted">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
        </Style>
        <Style Selector="Button.toolbar:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Button.icon">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="36" />
        </Style>
        <Style Selector="Button.icon ic|FluentIcon.glyph">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.pill">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style Selector="Button.pill:pointerover">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
        </Style>
        <Style Selector="Button.view-toggle.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        </Style>
        <Style Selector="Button.sidebar-row">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="8,7" />
        </Style>
        <Style Selector="Button.sidebar-row /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.sidebar-row:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinHeight" Value="46" />
        </Style>
        <Style Selector="Button.action:pointerover">
            <Setter Property="Background" Value="{StaticResource HoverBrush}" />
        </Style>
        <Style Selector="Button.action:disabled">
            <Setter Property="Opacity" Value="0.45" />
        </Style>
        <Style Selector="Border.tile">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Border.tile:pointerover">
            <Setter Property="Background" Value="#66F4FBF8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
        </Style>
        <Style Selector="Border.tile.selected">
            <Setter Property="Background" Value="{StaticResource SelectedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
        <Style Selector="Border.tile.drop-target">
            <Setter Property="BorderBrush" Value="{StaticResource CoralBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="Border.check-dot">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="2" />
        </Style>
        <Style Selector="TextBox.search">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="54,*,60" Background="{StaticResource AppBackgroundBrush}">
        <Border
            Grid.Row="0"
            Background="{StaticResource ChromeBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,0,0,1"
            AutomationProperties.AccessibilityView="Control"
            AutomationProperties.ControlTypeOverride="Pane"
            AutomationProperties.AutomationId="AppTitleBar">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="14,0" ColumnSpacing="12">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button
                        Classes="toolbar icon"
                        ToolTip.Tip="收合側欄"
                        AutomationProperties.AutomationId="TitleBarSidebarToggleButton"
                        Command="{Binding ToggleSidebarCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="PanelLeft" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                    <TextBlock Text="PicLens" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="2"
                    VerticalAlignment="Center">
                    <Button Classes="toolbar icon" ToolTip.Tip="上一個資料夾" AutomationProperties.AutomationId="TitleBarBackButton" Command="{Binding BackCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="ArrowLeft" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                    <Button Classes="toolbar icon" ToolTip.Tip="下一個資料夾" AutomationProperties.AutomationId="TitleBarForwardButton" Command="{Binding ForwardCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="ArrowRight" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                    <Button Classes="toolbar icon" ToolTip.Tip="重新整理" AutomationProperties.AutomationId="TitleBarRefreshLibraryButton" Command="{Binding RefreshLibraryCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="ArrowClockwise" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                    <Button Classes="toolbar icon" ToolTip.Tip="選擇資料夾" AutomationProperties.AutomationId="TitleBarOpenFolderButton" Command="{Binding OpenFolderCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="FolderOpen" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                    <TextBlock Text="{Binding CurrentFolderPath}" Classes="secondary" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="420" Margin="8,0,4,0" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBox
                        Classes="search"
                        Width="190"
                        PlaceholderText="搜尋圖片"
                        AutomationProperties.AutomationId="LibrarySearchBox"
                        Text="{Binding SearchQuery, Mode=TwoWay}" />
                    <Button Classes="toolbar icon" ToolTip.Tip="清除搜尋" AutomationProperties.AutomationId="LibrarySearchClearButton" IsVisible="{Binding HasSearchQuery}" Command="{Binding ClearSearchCommand}">
                        <ic:FluentIcon Classes="glyph" Icon="Dismiss" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                    <Button Classes="pill" ToolTip.Tip="排序" AutomationProperties.AutomationId="TitleBarSortMenuButton">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Text="{Binding SortLabel}" VerticalAlignment="Center" />
                            <ic:FluentIcon Classes="glyph muted" Icon="ChevronDown" IconVariant="Regular" IconSize="Size16" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="名稱由小到大" AutomationProperties.AutomationId="SortByNameAscendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="name-asc" />
                                <MenuItem Header="名稱由大到小" AutomationProperties.AutomationId="SortByNameDescendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="name-desc" />
                                <MenuItem Header="修改時間最舊到最新" AutomationProperties.AutomationId="SortByModifiedAtAscendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="modified-asc" />
                                <MenuItem Header="修改時間最新到最舊" AutomationProperties.AutomationId="SortByModifiedAtDescendingMenuItem" Command="{Binding ChangeSortOptionCommand}" CommandParameter="modified-desc" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Classes="pill" ToolTip.Tip="子資料夾" AutomationProperties.AutomationId="TitleBarRecursiveModeToggle" Command="{Binding ToggleIncludeSubfoldersCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <TextBlock Text="{Binding RecursiveModeLabel}" VerticalAlignment="Center" />
                            <Border Width="28" Height="16" CornerRadius="8" Background="{StaticResource AccentBrush}">
                                <Border Width="12" Height="12" CornerRadius="6" Background="White" HorizontalAlignment="Right" Margin="2" />
                            </Border>
                        </StackPanel>
                    </Button>
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Classes="toolbar icon view-toggle" Classes.active="{Binding IsGridViewMode}" ToolTip.Tip="格狀檢視" AutomationProperties.AutomationId="TitleBarGridViewButton" Command="{Binding SetViewModeCommand}" CommandParameter="grid">
                            <ic:FluentIcon Classes="glyph" Icon="LayoutColumnTwo" IconVariant="Regular" IconSize="Size20" />
                        </Button>
                        <Button Classes="toolbar icon view-toggle" Classes.active="{Binding IsListViewMode}" ToolTip.Tip="列表檢視" AutomationProperties.AutomationId="TitleBarListViewButton" Command="{Binding SetViewModeCommand}" CommandParameter="list">
                            <ic:FluentIcon Classes="glyph" Icon="TextBulletListSquare" IconVariant="Regular" IconSize="Size20" />
                        </Button>
                    </StackPanel>
                    <Button Classes="toolbar icon" ToolTip.Tip="更多" AutomationProperties.AutomationId="TitleBarMoreActionsButton">
                        <ic:FluentIcon Classes="glyph" Icon="MoreVertical" IconVariant="Regular" IconSize="Size20" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="將目前顯示項目轉為 JPG" AutomationProperties.AutomationId="TitleBarConvertVisibleButton" Command="{Binding ConvertVisibleCommand}" />
                                <MenuItem Header="清除同名非 JPG 檔案" AutomationProperties.AutomationId="TitleBarClearSameBasenameButton" Command="{Binding ClearSameBasenameCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,4,*" Margin="12,10,12,4">
            <Border
                Grid.Column="0"
                Width="250"
                Padding="12"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                IsVisible="{Binding IsSidebarOpen}">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Spacing="8" Margin="0,2,0,10">
                        <TextBlock Text="圖片集" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CurrentFolderName}" Classes="secondary" FontSize="12" TextTrimming="CharacterEllipsis" IsVisible="{Binding HasCurrentFolder}" />
                    </StackPanel>
                    <TreeView
                        x:Name="FolderTree"
                        Grid.Row="1"
                        AutomationProperties.AutomationId="FolderTree"
                        ItemsSource="{Binding FolderRoots}"
                        SelectionChanged="FolderTree_SelectionChanged">
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.Styles>
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate DataType="vm:FolderTreeItem" ItemsSource="{Binding Children}" x:DataType="vm:FolderTreeItem">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Classes="glyph" Icon="Folder" IconVariant="Regular" IconSize="Size20" />
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="Transparent" IsVisible="{Binding IsSidebarOpen}" />

            <Border Grid.Column="2" Classes="panel" Padding="18,16,18,0" Margin="8,0">
                <Grid RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding CurrentParentFolderName}" Classes="secondary" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="›" Classes="muted" FontSize="20" IsVisible="{Binding HasCurrentFolder}" />
                                <TextBlock Text="{Binding CurrentFolderName}" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Text="{Binding LibraryItemCountText}" Classes="caption" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding SearchQuery, StringFormat='搜尋：{0}'}" Classes="caption" VerticalAlignment="Center" IsVisible="{Binding HasSearchQuery}" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <ScrollViewer
                            x:Name="LibraryGrid"
                            AutomationProperties.AutomationId="LibraryGrid"
                            Focusable="True"
                            KeyDown="LibraryGrid_KeyDown"
                            HorizontalScrollBarVisibility="Disabled"
                            IsScrollInertiaEnabled="True">
                            <ScrollViewer.Transitions>
                                <Transitions>
                                    <VectorTransition Property="Offset" Duration="0:0:0.14" />
                                </Transitions>
                            </ScrollViewer.Transitions>
                            <StackPanel Spacing="18" Margin="0,0,0,20">
                                <StackPanel Spacing="10" IsVisible="{Binding HasFolderLibraryItems}">
                                    <TextBlock Text="{Binding FolderItemCountText}" FontSize="16" FontWeight="SemiBold" />
                                    <ir:ItemsRepeater ItemsSource="{Binding FolderLibraryItems}" ItemTemplate="{StaticResource LibraryTileTemplate}">
                                        <ir:ItemsRepeater.Layout>
                                            <irlayout:UniformGridLayout
                                                MinItemWidth="{Binding LibraryLayoutMinItemWidth}"
                                                MinItemHeight="{Binding LibraryTileLayoutHeight}"
                                                MinRowSpacing="12"
                                                MinColumnSpacing="10" />
                                        </ir:ItemsRepeater.Layout>
                                    </ir:ItemsRepeater>
                                </StackPanel>

                                <StackPanel Spacing="10" IsVisible="{Binding HasImageLibraryItems}">
                                    <TextBlock Text="{Binding ImageItemCountText}" FontSize="16" FontWeight="SemiBold" />
                                    <ir:ItemsRepeater ItemsSource="{Binding ImageLibraryItems}" ItemTemplate="{StaticResource LibraryTileTemplate}">
                                        <ir:ItemsRepeater.Layout>
                                            <irlayout:UniformGridLayout
                                                MinItemWidth="{Binding LibraryLayoutMinItemWidth}"
                                                MinItemHeight="{Binding LibraryTileLayoutHeight}"
                                                MinRowSpacing="12"
                                                MinColumnSpacing="10" />
                                        </ir:ItemsRepeater.Layout>
                                    </ir:ItemsRepeater>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" IsVisible="{Binding HasNoCurrentFolder}">
                            <TextBlock Text="尚未選擇資料夾" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <Button Content="選擇資料夾" Classes="pill" HorizontalAlignment="Center" AutomationProperties.AutomationId="EmptyStateOpenFolderButton" Command="{Binding OpenFolderCommand}" />
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" IsVisible="{Binding HasNoVisibleItems}">
                            <TextBlock Text="找不到符合條件的項目" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="清除搜尋或換個關鍵字。" Classes="secondary" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border
                x:Name="LibraryDragPreviewOverlay"
                IsVisible="False"
                Background="{StaticResource AccentBrush}"
                CornerRadius="8"
                Padding="10,6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                ZIndex="20">
                <TextBlock x:Name="LibraryDragPreviewText" Foreground="White" />
            </Border>
        </Grid>

        <Border
            Grid.Row="2"
            Background="{StaticResource ChromeBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,1,0,0"
            Padding="24,8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Orientation="Horizontal" Spacing="10" AutomationProperties.AutomationId="StatusBar">
                    <Border Width="22" Height="22" Background="{StaticResource AccentBrush}" CornerRadius="11" VerticalAlignment="Center">
                        <TextBlock Text="✓" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock AutomationProperties.AutomationId="StatusInfoBar" Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="縮圖大小" Classes="secondary" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ThumbnailSizeLabel}" Classes="caption" VerticalAlignment="Center" />
                    <Slider
                        x:Name="ThumbnailSizeSlider"
                        AutomationProperties.AutomationId="ThumbnailSizeSlider"
                        Minimum="{Binding ThumbnailSizeMinimum}"
                        Maximum="{Binding ThumbnailSizeMaximum}"
                        TickFrequency="{Binding ThumbnailSizeStep}"
                        Value="{Binding ThumbnailSize, Mode=TwoWay}"
                        Width="160"
                        LostFocus="ThumbnailSizeSlider_CommitValue"
                        PointerCaptureLost="ThumbnailSizeSlider_CommitValue"
                        KeyUp="ThumbnailSizeSlider_KeyUp" />
                    <ic:FluentIcon Classes="glyph muted" Icon="ImageMultiple" IconVariant="Regular" IconSize="Size16" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            x:Name="ViewerSurface"
            Grid.Row="0"
            Grid.RowSpan="3"
            IsVisible="False"
            Focusable="True"
            Background="#D9FAF9F6"
            KeyDown="ViewerSurface_KeyDown"
            x:DataType="vm:ImageViewerWindowViewModel"
            AutomationProperties.AutomationId="ViewerSurface"
            ZIndex="50">
            <Grid RowDefinitions="Auto,*,Auto" Margin="24">
                <Border Grid.RowSpan="3" Background="{StaticResource ViewerCanvasBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" />
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="18,14" IsVisible="{Binding IsChromeVisible}">
                    <TextBlock Text="{Binding CurrentImageName}" Classes="secondary" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="1" Classes="toolbar icon" ToolTip.Tip="關閉" AutomationProperties.AutomationId="ViewerCloseButton" Click="CloseViewer_Click">
                        <ic:FluentIcon Classes="glyph" Icon="Dismiss" IconVariant="Regular" IconSize="Size20" />
                    </Button>
                </Grid>
                <Grid
                    x:Name="ViewerImageSurface"
                    Grid.Row="1"
                    ClipToBounds="True"
                    Background="{StaticResource ViewerCanvasBrush}"
                    SizeChanged="ViewerImageSurface_SizeChanged"
                    PointerWheelChanged="ViewerImageSurface_PointerWheelChanged"
                    PointerPressed="ViewerImageSurface_PointerPressed"
                    PointerMoved="ViewerImageSurface_PointerMoved"
                    PointerReleased="ViewerImageSurface_PointerReleased"
                    PointerCaptureLost="ViewerImageSurface_PointerCaptureLost">
                    <Image
                        x:Name="ViewerImage"
                        AutomationProperties.AutomationId="ViewerImage"
                        AutomationProperties.Name="{Binding CurrentImageName}"
                        Source="{Binding CurrentImageSourcePath, Converter={StaticResource ImagePathConverter}}"
                        Stretch="Uniform"
                        IsVisible="{Binding IsImageVisible}"
                        RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Zoom}" ScaleY="{Binding Zoom}" />
                                <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}" />
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <TextBlock
                        Text="{Binding UnsupportedMessage}"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        FontSize="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsUnsupportedAnimatedImage}" />
                </Grid>
                <Border Grid.Row="2" Background="#E61F2328" CornerRadius="8" Padding="8" HorizontalAlignment="Center" Margin="0,0,0,16" IsVisible="{Binding IsChromeVisible}">
                    <StackPanel Orientation="Horizontal" Spacing="6" AutomationProperties.AutomationId="ViewerTitleCommandBar">
                        <Button Classes="toolbar icon" ToolTip.Tip="上一張" AutomationProperties.AutomationId="ViewerPreviousButton" Command="{Binding PreviousCommand}">
                            <ic:FluentIcon Classes="glyph" Icon="ArrowLeft" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                        </Button>
                        <Button Classes="toolbar" ToolTip.Tip="上一張" Command="{Binding PreviousCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ic:FluentIcon Classes="glyph" Icon="ArrowLeft" IconVariant="Regular" IconSize="Size16" Foreground="White" />
                                <TextBlock Text="上一張" Foreground="White" />
                            </StackPanel>
                        </Button>
                        <Button Classes="toolbar icon" ToolTip.Tip="縮小" AutomationProperties.AutomationId="ViewerZoomOutButton" Command="{Binding ZoomOutCommand}">
                            <ic:FluentIcon Classes="glyph" Icon="ZoomOut" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                        </Button>
                        <TextBlock Text="{Binding Zoom, StringFormat='{}{0:P0}'}" Foreground="White" VerticalAlignment="Center" MinWidth="54" TextAlignment="Center" />
                        <Button Classes="toolbar icon" ToolTip.Tip="放大" AutomationProperties.AutomationId="ViewerZoomInButton" Command="{Binding ZoomInCommand}">
                            <ic:FluentIcon Classes="glyph" Icon="ZoomIn" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                        </Button>
                        <Button Classes="toolbar icon" ToolTip.Tip="重設" AutomationProperties.AutomationId="ViewerResetZoomButton" Command="{Binding ResetZoomCommand}">
                            <ic:FluentIcon Classes="glyph" Icon="ArrowClockwise" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                        </Button>
                        <Button Classes="toolbar" ToolTip.Tip="下一張" Command="{Binding NextCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="下一張" Foreground="White" />
                                <ic:FluentIcon Classes="glyph" Icon="ArrowRight" IconVariant="Regular" IconSize="Size16" Foreground="White" />
                            </StackPanel>
                        </Button>
                        <Button Classes="toolbar icon" ToolTip.Tip="下一張" AutomationProperties.AutomationId="ViewerNextButton" Command="{Binding NextCommand}">
                            <ic:FluentIcon Classes="glyph" Icon="ArrowRight" IconVariant="Regular" IconSize="Size20" Foreground="White" />
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
