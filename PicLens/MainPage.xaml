<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PicLens.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PicLens"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PicLens.ViewModels"
    mc:Ignorable="d">
    <Grid
        x:Name="Root"
        Padding="0"
        Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
        ColumnSpacing="0"
        IsTabStop="True"
        KeyDown="Root_KeyDown"
        PointerReleased="Root_PointerReleased">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideWindow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1008" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="FolderColumn.Width" Value="280" />
                        <Setter Target="FolderPane.Visibility" Value="Visible" />
                        <Setter Target="LibraryContent.Padding" Value="20,16,20,16" />
                        <Setter Target="ThumbnailSizeSlider.Width" Value="160" />
                        <Setter Target="ThumbnailSizePanel.(Grid.Row)" Value="0" />
                        <Setter Target="ThumbnailSizePanel.(Grid.Column)" Value="1" />
                        <Setter Target="ThumbnailSizePanel.HorizontalAlignment" Value="Right" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="MediumWindow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="641" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="FolderColumn.Width" Value="252" />
                        <Setter Target="FolderPane.Visibility" Value="Visible" />
                        <Setter Target="LibraryContent.Padding" Value="20,16,20,16" />
                        <Setter Target="ThumbnailSizeSlider.Width" Value="144" />
                        <Setter Target="ThumbnailSizePanel.(Grid.Row)" Value="0" />
                        <Setter Target="ThumbnailSizePanel.(Grid.Column)" Value="1" />
                        <Setter Target="ThumbnailSizePanel.HorizontalAlignment" Value="Right" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="CompactWindow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="FolderColumn.Width" Value="0" />
                        <Setter Target="FolderPane.Visibility" Value="Collapsed" />
                        <Setter Target="LibraryContent.Padding" Value="16,16,16,16" />
                        <Setter Target="ThumbnailSizeSlider.Width" Value="128" />
                        <Setter Target="ThumbnailSizePanel.(Grid.Row)" Value="1" />
                        <Setter Target="ThumbnailSizePanel.(Grid.Column)" Value="0" />
                        <Setter Target="ThumbnailSizePanel.HorizontalAlignment" Value="Right" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.Resources>
            <MenuFlyout x:Name="LibraryImageContextFlyout">
                <MenuFlyoutItem
                    AutomationProperties.AutomationId="ImageContextRevealInFileExplorerButton"
                    AutomationProperties.Name="在檔案總管中顯示"
                    Click="RevealInFileExplorer"
                    Text="在檔案總管中顯示">
                    <MenuFlyoutItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8E5;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    AutomationProperties.AutomationId="ImageContextRenameButton"
                    AutomationProperties.Name="重新命名選取的圖片"
                    Command="{x:Bind ViewModel.RenameSelectedCommand}"
                    Text="重新命名">
                    <MenuFlyoutItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE8AC;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
                <MenuFlyoutItem
                    AutomationProperties.AutomationId="ImageContextTrashButton"
                    AutomationProperties.Name="將選取的圖片移至回收筒"
                    Command="{x:Bind ViewModel.TrashSelectedCommand}"
                    Text="移至回收筒">
                    <MenuFlyoutItem.Icon>
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74D;" />
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
            <MenuFlyout x:Name="SortMenuFlyout">
                <MenuFlyoutItem
                    x:Name="SortByNameAscendingMenuItem"
                    AutomationProperties.AutomationId="SortByNameAscendingMenuItem"
                    Text="名稱由小到大" />
                <MenuFlyoutItem
                    x:Name="SortByNameDescendingMenuItem"
                    AutomationProperties.AutomationId="SortByNameDescendingMenuItem"
                    Text="名稱由大到小" />
                <MenuFlyoutItem
                    x:Name="SortByModifiedAtAscendingMenuItem"
                    AutomationProperties.AutomationId="SortByModifiedAtAscendingMenuItem"
                    Text="修改時間最舊到最新" />
                <MenuFlyoutItem
                    x:Name="SortByModifiedAtDescendingMenuItem"
                    AutomationProperties.AutomationId="SortByModifiedAtDescendingMenuItem"
                    Text="修改時間最新到最舊" />
            </MenuFlyout>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="FolderColumn" Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            x:Name="TopCommandChrome"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Padding="8,4,8,4"
            AutomationProperties.AutomationId="FolderNavigationCommandBar"
            AutomationProperties.Name="全域導覽與圖庫工具列"
            Background="{ThemeResource LayerOnMicaBaseAltFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <CommandBar
                    AutomationProperties.AutomationId="LibraryCommandBar"
                    Background="Transparent"
                    DefaultLabelPosition="Right"
                    IsDynamicOverflowEnabled="True">
                    <AppBarButton
                        x:Name="TitleBarBackButton"
                        AutomationProperties.AutomationId="TitleBarBackButton"
                        AutomationProperties.Name="上一頁"
                        Width="42"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="返回上一個資料夾"
                        Command="{x:Bind ViewModel.BackCommand}"
                        Icon="Back"
                        Label="上一頁"
                        LabelPosition="Collapsed"
                        IsCompact="True" />
                    <AppBarButton
                        x:Name="TitleBarForwardButton"
                        AutomationProperties.AutomationId="TitleBarForwardButton"
                        AutomationProperties.Name="下一頁"
                        Width="42"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="前進到下一個資料夾"
                        Command="{x:Bind ViewModel.ForwardCommand}"
                        Icon="Forward"
                        Label="下一頁"
                        LabelPosition="Collapsed"
                        IsCompact="True" />
                    <AppBarButton
                        x:Name="TitleBarRefreshLibraryButton"
                        Grid.Column="2"
                        AutomationProperties.AutomationId="TitleBarRefreshLibraryButton"
                        AutomationProperties.Name="重新整理"
                        Width="42"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="重新整理圖庫"
                        Command="{x:Bind ViewModel.RefreshLibraryCommand}"
                        Icon="Refresh"
                        Label="重新整理"
                        LabelPosition="Collapsed"
                        IsCompact="True" />
                    <AppBarSeparator />
                    <AppBarButton
                        x:Name="TitleBarOpenFolderButton"
                        AutomationProperties.AutomationId="TitleBarOpenFolderButton"
                        AutomationProperties.Name="選擇資料夾"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="選擇資料夾"
                        Command="{x:Bind ViewModel.OpenFolderCommand}"
                        Label="選擇資料夾">
                        <AppBarButton.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE838;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton
                        x:Name="TitleBarSortMenuButton"
                        AutomationProperties.AutomationId="TitleBarSortMenuButton"
                        AutomationProperties.Name="排序"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="排序"
                        Click="ShowSortMenu"
                        Icon="Sort"
                        Label="{x:Bind ViewModel.SelectedSortOption.Label, Mode=OneWay}" />
                    <AppBarButton
                        x:Name="TitleBarRecursiveModeToggle"
                        AutomationProperties.AutomationId="TitleBarRecursiveModeToggle"
                        AutomationProperties.Name="包含子資料夾"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="包含或排除子資料夾"
                        Command="{x:Bind ViewModel.ToggleIncludeSubfoldersCommand}"
                        Label="{x:Bind ViewModel.RecursiveModeLabel, Mode=OneWay}">
                        <AppBarButton.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xF89A;" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarSeparator />
                    <AppBarButton
                        x:Name="TitleBarMoreActionsButton"
                        AutomationProperties.AutomationId="TitleBarMoreActionsButton"
                        AutomationProperties.Name="更多圖庫動作"
                        Width="42"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="更多圖庫動作"
                        Label="更多圖庫動作"
                        LabelPosition="Collapsed"
                        IsCompact="True">
                        <AppBarButton.Icon>
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE712;" />
                        </AppBarButton.Icon>
                        <AppBarButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuFlyoutItem
                                    x:Name="TitleBarConvertVisibleButton"
                                    AutomationProperties.AutomationId="TitleBarConvertVisibleButton"
                                    AutomationProperties.Name="將目前顯示項目轉為 JPG"
                                    Command="{x:Bind ViewModel.ConvertVisibleCommand}"
                                    Text="將目前顯示項目轉為 JPG">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEE71;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    x:Name="TitleBarClearSameBasenameButton"
                                    AutomationProperties.AutomationId="TitleBarClearSameBasenameButton"
                                    AutomationProperties.Name="清除同名非 JPG 檔案"
                                    Command="{x:Bind ViewModel.ClearSameBasenameCommand}"
                                    Text="清除同名非 JPG 檔案">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE75C;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                </CommandBar>
            </Grid>
        </Border>

        <Grid
            x:Name="FolderPane"
            Grid.Row="1"
            Padding="16,16,8,16"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,1,0"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="資料夾" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="{x:Bind ViewModel.CurrentFolderPath, Mode=OneWay}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextTrimming="CharacterEllipsis"
                    Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>

            <TreeView
                Grid.Row="1"
                AutomationProperties.AutomationId="FolderTree"
                AutomationProperties.Name="資料夾樹"
                ItemsSource="{x:Bind ViewModel.FolderRoots, Mode=OneWay}"
                ItemInvoked="FolderTree_ItemInvoked"
                Expanding="FolderTree_Expanding">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="vm:FolderTreeItem">
                        <TreeViewItem
                            IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                            IsSelected="{x:Bind IsSelected, Mode=TwoWay}"
                            ItemsSource="{x:Bind Children, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" />
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}" />
                            </StackPanel>
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <Grid
            x:Name="LibraryContent"
            Grid.Row="1"
            Grid.Column="1"
            Padding="20,16,20,16"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid MinHeight="52" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid
                    x:Name="LibraryHeaderPath"
                    VerticalAlignment="Center"
                    ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="LibraryHeaderParentText"
                        VerticalAlignment="Center"
                        MaxWidth="220"
                        Text="{x:Bind ViewModel.CurrentParentFolderName, Mode=OneWay}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        Style="{StaticResource SubtitleTextBlockStyle}" />
                    <FontIcon
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Glyph="&#xE974;" />
                    <TextBlock
                        x:Name="LibraryHeaderCurrentText"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.CurrentFolderName, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        Style="{StaticResource TitleTextBlockStyle}" />
                </Grid>

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="{x:Bind ViewModel.LibraryItemCountText, Mode=OneWay}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource BodyStrongTextBlockStyle}" />
            </Grid>

            <Grid
                x:Name="LibraryGridSurface"
                Grid.Row="1"
                AutomationProperties.AccessibilityView="Control"
                AutomationProperties.AutomationId="LibraryGrid"
                AutomationProperties.Name="圖庫項目">
                <GridView
                    x:Name="LibraryGrid"
                    ContainerContentChanging="LibraryGrid_ContainerContentChanging"
                    DoubleTapped="LibraryGrid_DoubleTapped"
                    IsItemClickEnabled="False"
                    IsTabStop="True"
                    ItemsSource="{x:Bind ViewModel.LibraryItems, Mode=OneWay}"
                    KeyDown="LibraryGrid_KeyDown"
                    PointerCanceled="LibraryGrid_PointerCanceled"
                    PointerCaptureLost="LibraryGrid_PointerCaptureLost"
                    PointerMoved="LibraryGrid_PointerMoved"
                    PointerReleased="LibraryGrid_PointerReleased"
                    SelectionChanged="LibraryGrid_SelectionChanged"
                    SelectionMode="Multiple"
                    Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.HasCurrentFolder), Mode=OneWay}">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem" BasedOn="{StaticResource DefaultGridViewItemStyle}">
                            <Setter Property="Margin" Value="0,0,12,12" />
                            <Setter Property="MinWidth" Value="128" />
                            <Setter Property="MinHeight" Value="136" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="vm:LibraryTileItem">
                            <Grid
                                AutomationProperties.AutomationId="{x:Bind AutomationId, Mode=OneWay}"
                                AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}"
                                Width="{x:Bind TileWidth, Mode=OneWay}"
                                Height="{x:Bind TileHeight, Mode=OneWay}"
                                Loaded="LibraryTile_Loaded"
                                PointerPressed="LibraryTile_PointerPressed"
                                RowSpacing="8"
                                RightTapped="LibraryTile_RightTapped"
                                Tapped="LibraryTile_Tapped"
                                Unloaded="LibraryTile_Unloaded">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{ThemeResource ControlCornerRadius}">
                                    <Grid>
                                        <Image
                                            Source="{x:Bind local:MainPage.CreateBitmapImage(ThumbnailPath), Mode=OneWay}"
                                            Stretch="Uniform"
                                            Visibility="{x:Bind local:MainPage.BoolToVisibility(CanShowThumbnail), Mode=OneWay}" />
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Glyph="{x:Bind IconGlyph, Mode=OneTime}"
                                            Visibility="{x:Bind local:MainPage.BoolToVisibility(ShouldShowIcon), Mode=OneWay}" />
                                    </Grid>
                                </Border>

                                <TextBlock
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    TextAlignment="Center"
                                    Text="{x:Bind Name, Mode=OneWay}"
                                    TextWrapping="Wrap"
                                    MaxLines="2"
                                    TextTrimming="CharacterEllipsis"
                                    Style="{StaticResource BodyStrongTextBlockStyle}" />

                                <Border
                                    Grid.RowSpan="2"
                                    IsHitTestVisible="False"
                                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                    BorderThickness="2"
                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                    Visibility="{x:Bind local:MainPage.BoolToVisibility(IsDropRenameTarget), Mode=OneWay}" />
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <Grid
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="360"
                    RowSpacing="12"
                    Visibility="{x:Bind local:MainPage.InvertBoolToVisibility(ViewModel.HasCurrentFolder), Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <FontIcon
                        HorizontalAlignment="Center"
                        Glyph="&#xE8B7;" />
                    <TextBlock
                        Grid.Row="1"
                        Text="請先選擇資料夾"
                        TextAlignment="Center"
                        Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Button
                        Grid.Row="2"
                        HorizontalAlignment="Center"
                        AutomationProperties.AutomationId="EmptyStateOpenFolderButton"
                        Command="{x:Bind ViewModel.OpenFolderCommand}"
                        Content="選擇資料夾" />
                </Grid>

                <Border
                    x:Name="LibraryDragPreviewOverlay"
                    MaxWidth="320"
                    MinHeight="40"
                    Padding="12,8"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    AutomationProperties.Name="拖曳中的圖片"
                    Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="LibraryDragPreviewTransform" />
                    </Border.RenderTransform>
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <FontIcon
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            Glyph="&#xE8B9;" />
                        <TextBlock
                            x:Name="LibraryDragPreviewText"
                            MaxWidth="260"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Padding="24,4"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid
                x:Name="StatusBarContent"
                ColumnSpacing="16"
                RowSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <InfoBar
                    AutomationProperties.AutomationId="StatusInfoBar"
                    AutomationProperties.HelpText="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    AutomationProperties.LiveSetting="Polite"
                    AutomationProperties.Name="檔案操作狀態"
                    IsClosable="False"
                    IsOpen="True"
                    Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    Severity="{x:Bind local:MainPage.StatusSeverityToInfoBarSeverity(ViewModel.StatusSeverity), Mode=OneWay}"
                    Title="檔案操作" />

                <StackPanel
                    x:Name="ThumbnailSizePanel"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <FontIcon
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        Glyph="&#xECA5;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.ThumbnailSizeLabel, Mode=OneWay}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}" />
                    <Slider
                        x:Name="ThumbnailSizeSlider"
                        AutomationProperties.AutomationId="ThumbnailSizeSlider"
                        AutomationProperties.Name="縮圖大小"
                        Width="160"
                        LargeChange="{x:Bind ViewModel.ThumbnailSizeStep, Mode=OneWay}"
                        Maximum="{x:Bind ViewModel.ThumbnailSizeMaximum, Mode=OneWay}"
                        Minimum="{x:Bind ViewModel.ThumbnailSizeMinimum, Mode=OneWay}"
                        SmallChange="{x:Bind ViewModel.ThumbnailSizeStep, Mode=OneWay}"
                        StepFrequency="{x:Bind ViewModel.ThumbnailSizeStep, Mode=OneWay}"
                        ToolTipService.ToolTip="調整縮圖大小"
                        Value="{x:Bind ViewModel.ThumbnailSize, Mode=OneWay}"
                        KeyUp="ThumbnailSizeSlider_KeyUp"
                        LostFocus="ThumbnailSizeSlider_CommitValue"
                        PointerCaptureLost="ThumbnailSizeSlider_CommitValue" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            x:Name="ViewerSurface"
            Grid.RowSpan="3"
            Grid.ColumnSpan="2"
            AutomationProperties.AccessibilityView="Control"
            AutomationProperties.AutomationId="ViewerSurface"
            AutomationProperties.Name="{x:Bind PreviewViewModel.CurrentImageName, Mode=OneWay}"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
            IsTabStop="True"
            KeyDown="Root_KeyDown"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TitleBar
                x:Name="ViewerTitleBar"
                AutomationProperties.AutomationId="ViewerTitleBar"
                Title="{x:Bind PreviewViewModel.CurrentImageName, Mode=OneWay}"
                Subtitle="{x:Bind PreviewViewModel.PositionLabel, Mode=OneWay}">
                <TitleBar.IconSource>
                    <ImageIconSource ImageSource="Assets/AppIcon.ico" />
                </TitleBar.IconSource>
                <TitleBar.RightHeader>
                    <CommandBar
                        AutomationProperties.AutomationId="ViewerTitleCommandBar"
                        Background="Transparent"
                        DefaultLabelPosition="Collapsed"
                        IsDynamicOverflowEnabled="True">
                        <AppBarButton
                            AutomationProperties.AutomationId="ViewerPreviousButton"
                            AutomationProperties.Name="上一張圖片"
                            ToolTipService.ToolTip="上一張圖片"
                            Command="{x:Bind PreviewViewModel.PreviousCommand}"
                            Label="上一張">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Back" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            AutomationProperties.AutomationId="ViewerNextButton"
                            AutomationProperties.Name="下一張圖片"
                            ToolTipService.ToolTip="下一張圖片"
                            Command="{x:Bind PreviewViewModel.NextCommand}"
                            Label="下一張">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Forward" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarSeparator />
                        <AppBarButton
                            AutomationProperties.AutomationId="ViewerZoomOutButton"
                            AutomationProperties.Name="縮小"
                            ToolTipService.ToolTip="縮小"
                            Command="{x:Bind PreviewViewModel.ZoomOutCommand}"
                            Label="縮小">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="ZoomOut" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            AutomationProperties.AutomationId="ViewerResetZoomButton"
                            AutomationProperties.Name="重設縮放"
                            ToolTipService.ToolTip="重設縮放"
                            Command="{x:Bind PreviewViewModel.ResetZoomCommand}"
                            Label="重設縮放">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Refresh" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            AutomationProperties.AutomationId="ViewerZoomInButton"
                            AutomationProperties.Name="放大"
                            ToolTipService.ToolTip="放大"
                            Command="{x:Bind PreviewViewModel.ZoomInCommand}"
                            Label="放大">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="ZoomIn" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarSeparator />
                        <AppBarButton
                            AutomationProperties.AutomationId="ViewerCloseButton"
                            AutomationProperties.Name="關閉預覽"
                            ToolTipService.ToolTip="關閉預覽"
                            Click="CloseViewer"
                            Label="關閉">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Cancel" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar>
                </TitleBar.RightHeader>
            </TitleBar>

            <Grid
                x:Name="ViewerImageSurface"
                Grid.Row="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                PointerCanceled="ViewerImageSurface_PointerReleased"
                PointerMoved="ViewerImageSurface_PointerMoved"
                PointerPressed="ViewerImageSurface_PointerPressed"
                PointerReleased="ViewerImageSurface_PointerReleased"
                PointerWheelChanged="ViewerImageSurface_PointerWheelChanged"
                SizeChanged="ViewerImageSurface_SizeChanged">
                <Image
                    x:Name="ViewerImage"
                    AutomationProperties.AutomationId="ViewerImage"
                    AutomationProperties.Name="{x:Bind PreviewViewModel.CurrentImageName, Mode=OneWay}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Source="{x:Bind local:MainPage.CreateBitmapImage(PreviewViewModel.CurrentImageSourcePath), Mode=OneWay}"
                    Stretch="Uniform"
                    RenderTransformOrigin="0.5,0.5"
                    Visibility="{x:Bind local:MainPage.BoolToVisibility(PreviewViewModel.IsImageVisible), Mode=OneWay}">
                    <Image.RenderTransform>
                        <CompositeTransform
                            ScaleX="{x:Bind PreviewViewModel.Zoom, Mode=OneWay}"
                            ScaleY="{x:Bind PreviewViewModel.Zoom, Mode=OneWay}"
                            TranslateX="{x:Bind PreviewViewModel.OffsetX, Mode=OneWay}"
                            TranslateY="{x:Bind PreviewViewModel.OffsetY, Mode=OneWay}" />
                    </Image.RenderTransform>
                </Image>

                <Grid
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind local:MainPage.BoolToVisibility(PreviewViewModel.IsUnsupportedAnimatedImage), Mode=OneWay}">
                    <Border
                        MaxWidth="520"
                        Padding="24"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BackgroundSizing="InnerBorderEdge"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource OverlayCornerRadius}">
                        <StackPanel Spacing="12">
                            <FontIcon
                                HorizontalAlignment="Center"
                                Glyph="&#xE783;" />
                            <TextBlock
                                Text="無法預覽動畫"
                                TextAlignment="Center"
                                Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock
                                Text="{x:Bind PreviewViewModel.UnsupportedMessage, Mode=OneWay}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextAlignment="Center"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid
                Grid.Row="2"
                AutomationProperties.AccessibilityView="Control"
                MinHeight="32"
                Padding="16,4"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    AutomationProperties.AutomationId="ViewerStatusBar"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="{x:Bind PreviewViewModel.CurrentImageName, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind PreviewViewModel.ZoomLabel, Mode=OneWay}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
            </Grid>
        </Grid>
    </Grid>
</Page>
