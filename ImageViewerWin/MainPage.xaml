<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ImageViewerWin.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ImageViewerWin"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ImageViewerWin.ViewModels"
    mc:Ignorable="d">

    <Grid
        x:Name="Root"
        Padding="0"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        ColumnSpacing="0"
        PointerReleased="Root_PointerReleased">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            Grid.RowSpan="3"
            Padding="20,16"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,1,0"
            RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="資料夾" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="{x:Bind ViewModel.CurrentFolderPath, Mode=OneWay}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextTrimming="CharacterEllipsis"
                    Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>

            <TreeView
                Grid.Row="1"
                AutomationProperties.AutomationId="FolderTree"
                ItemsSource="{x:Bind ViewModel.FolderRoots, Mode=OneWay}"
                ItemInvoked="FolderTree_ItemInvoked">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="vm:FolderTreeItem">
                        <TreeViewItem
                            IsExpanded="{x:Bind IsExpanded, Mode=OneTime}"
                            ItemsSource="{x:Bind Children}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                <TextBlock Text="{x:Bind Name}" />
                            </StackPanel>
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <CommandBar
            Grid.Column="1"
            AutomationProperties.AutomationId="LibraryCommandBar"
            Background="Transparent"
            DefaultLabelPosition="Right">
            <AppBarButton
                AutomationProperties.AutomationId="BackButton"
                Command="{x:Bind ViewModel.BackCommand}"
                Icon="Back"
                Label="返回" />
            <AppBarButton
                AutomationProperties.AutomationId="ForwardButton"
                Command="{x:Bind ViewModel.ForwardCommand}"
                Icon="Forward"
                Label="前進" />
            <AppBarSeparator />
            <AppBarButton
                AutomationProperties.AutomationId="OpenFolderButton"
                Command="{x:Bind ViewModel.OpenFolderCommand}"
                Icon="OpenFile"
                Label="選擇資料夾" />
            <AppBarButton
                AutomationProperties.AutomationId="RefreshLibraryButton"
                Command="{x:Bind ViewModel.RefreshLibraryCommand}"
                Icon="Refresh"
                Label="重新整理" />
            <AppBarButton
                AutomationProperties.AutomationId="SortKeyButton"
                Command="{x:Bind ViewModel.ToggleSortKeyCommand}"
                Icon="Sort"
                Label="{x:Bind ViewModel.SortLabel, Mode=OneWay}" />
            <AppBarButton
                AutomationProperties.AutomationId="SortDirectionButton"
                Command="{x:Bind ViewModel.ToggleSortDirectionCommand}"
                Icon="Sort"
                Label="方向" />
            <AppBarToggleButton
                AutomationProperties.AutomationId="RecursiveModeToggle"
                Icon="SyncFolder"
                IsChecked="{x:Bind ViewModel.IncludeSubfolders, Mode=TwoWay}"
                Label="{x:Bind ViewModel.RecursiveModeLabel, Mode=OneWay}" />
            <CommandBar.SecondaryCommands>
                <AppBarButton
                    AutomationProperties.AutomationId="ConvertVisibleButton"
                    Command="{x:Bind ViewModel.ConvertVisibleCommand}"
                    Icon="Save"
                    Label="將目前顯示項目轉為 JPG" />
                <AppBarButton
                    AutomationProperties.AutomationId="ClearSameBasenameButton"
                    Command="{x:Bind ViewModel.ClearSameBasenameCommand}"
                    Icon="Clear"
                    Label="清除同名非 JPG 檔案" />
                <AppBarButton
                    AutomationProperties.AutomationId="RenameSelectedButton"
                    Command="{x:Bind ViewModel.RenameSelectedCommand}"
                    Icon="Edit"
                    Label="重新命名選取的圖片" />
                <AppBarButton
                    AutomationProperties.AutomationId="TrashSelectedButton"
                    Command="{x:Bind ViewModel.TrashSelectedCommand}"
                    Icon="Delete"
                    Label="將選取項目移至回收筒" />
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <Grid
            Grid.Row="1"
            Grid.Column="1"
            Padding="24,12,24,20"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock Text="圖庫" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.CurrentFolderPath, Mode=OneWay}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Text="{x:Bind ViewModel.SortLabel, Mode=OneWay}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}" />
            </Grid>

            <GridView
                x:Name="LibraryGrid"
                Grid.Row="1"
                AllowDrop="True"
                AutomationProperties.AutomationId="LibraryGrid"
                CanDragItems="True"
                DragItemsStarting="LibraryGrid_DragItemsStarting"
                DragOver="LibraryGrid_DragOver"
                Drop="LibraryGrid_Drop"
                DoubleTapped="LibraryGrid_DoubleTapped"
                IsItemClickEnabled="False"
                IsTabStop="True"
                ItemsSource="{x:Bind ViewModel.LibraryItems, Mode=OneWay}"
                KeyDown="LibraryGrid_KeyDown"
                SelectionChanged="LibraryGrid_SelectionChanged"
                SelectionMode="Multiple"
                Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.HasCurrentFolder), Mode=OneWay}">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem" BasedOn="{StaticResource DefaultGridViewItemStyle}">
                        <Setter Property="Margin" Value="0,0,12,12" />
                        <Setter Property="MinWidth" Value="172" />
                        <Setter Property="MinHeight" Value="168" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:LibraryTileItem">
                        <Border
                            Width="172"
                            Height="168"
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{ThemeResource ControlCornerRadius}">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="{ThemeResource ControlCornerRadius}">
                                    <Image
                                        Source="{x:Bind local:MainPage.CreateBitmapImage(ThumbnailPath), Mode=OneTime}"
                                        Stretch="Uniform"
                                        Visibility="{x:Bind local:MainPage.BoolToVisibility(CanShowThumbnail), Mode=OneTime}" />
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Glyph="{x:Bind IconGlyph, Mode=OneTime}"
                                        FontSize="36"
                                        Visibility="{x:Bind local:MainPage.BoolToVisibility(ShouldShowIcon), Mode=OneTime}" />
                                </Grid>
                                <TextBlock
                                    Grid.Row="1"
                                    Text="{x:Bind Name}"
                                    TextTrimming="CharacterEllipsis"
                                    Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <StackPanel Grid.Row="2" Spacing="2">
                                    <TextBlock
                                        Text="{x:Bind KindLabel}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextTrimming="CharacterEllipsis"
                                        Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBlock
                                        Text="{x:Bind Detail}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextTrimming="CharacterEllipsis"
                                        Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <Grid
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="360"
                RowSpacing="12"
                Visibility="{x:Bind local:MainPage.InvertBoolToVisibility(ViewModel.HasCurrentFolder), Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <FontIcon
                    HorizontalAlignment="Center"
                    Glyph="&#xE8B7;"
                    FontSize="36" />
                <TextBlock
                    Grid.Row="1"
                    Text="請先選擇資料夾"
                    TextAlignment="Center"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <Button
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    AutomationProperties.AutomationId="EmptyStateOpenFolderButton"
                    Command="{x:Bind ViewModel.OpenFolderCommand}"
                    Content="選擇資料夾" />
            </Grid>
        </Grid>

        <InfoBar
            Grid.Row="2"
            Grid.Column="1"
            Margin="24,0,24,20"
            AutomationProperties.AutomationId="StatusInfoBar"
            IsClosable="False"
            IsOpen="True"
            Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
            Severity="Informational"
            Title="檔案操作" />
    </Grid>
</Page>
